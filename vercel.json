{
  "rewrites": [
    {
      "source": "/ahorros/:path*",
      "destination": "https://ahorros-personales.vercel.app/ahorros/:path*"
    },
    {
      "source": "/reparaciones/:path*",
      "destination": "https://gest-reparaciones.vercel.app/reparaciones/:path*"
    },
    {
      "source": "/:path*",
      "destination": "https://catalogo-servicios-web.vercel.app/:path*"
    }
  ]
}
